# --- Backend ---
# Which browser backend to use by default: chrome | playwright
#   chrome     = the headless Chrome container (docker compose service "chrome")
#   playwright = local Chromium launched inside the api container
BROWSER_BACKEND=chrome

# CDP endpoint for the chrome container. Playwright reads /json/version here.
CHROME_CDP_URL=http://chrome:3000

# Optional outbound proxy applied at Chrome launch (host:port or http://user:pass@host:port).
# Cannot be changed per-request; container restart required to swap.
CHROME_PROXY=

# CORS origin for the React app
FRONTEND_ORIGIN=http://localhost:5173

# Output directory for exported files (mounted into the api container)
OUTPUT_DIR=/app/output

# Scraping defaults
DEFAULT_COUNTRY=ALL
DEFAULT_AD_TYPE=all
DEFAULT_MAX_PAGES=50

# Playwright backend visibility (ignored by the chrome backend).
# false: open a real Chromium window so you can watch the automation.
# true:  run headless. Required inside Docker — there is no display.
PLAYWRIGHT_HEADLESS=false
# Optional slow-motion delay (ms) between Playwright actions. 0 disables.
PLAYWRIGHT_SLOW_MO_MS=0

# --- Proxy pool (Webshare residential) ---
# Comma- OR newline-separated `host:port:username:password` entries.
# Paste your Webshare-formatted list directly. Leave empty for no proxy.
# Health-checked on /proxies/refresh against http://www.gstatic.com/generate_204
WEBSHARE_PROXIES=

# --- LLM pagination (optional) ---
# Set to enable Gemini-driven "Load more" selector discovery. Without a
# key the scraper uses plain scroll-to-bottom and zero LLM calls.
# Free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Frontend ---
VITE_API_URL=http://localhost:8000
